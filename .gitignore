# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
vendor/

# Go workspace file
go.work

# Build output
_output/
bin/
/gpu-node-mocker

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Kubernetes manifests (generated)
config/

# Coverage reports
coverage.out
coverage.html
e2e-coverage-report.html
e2e-report-preview.html
e2e-summary-preview.md

# Local development
.env
*.local

# Temporary files
*.tmp
*.temp

# Helm dependency tarballs (vendored on demand via `helm dependency update`).
# Chart.lock IS committed so the resolved versions stay reproducible.
charts/**/charts/*.tgz
